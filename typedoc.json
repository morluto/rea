{
  "$schema": "https://typedoc.org/schema.json",
  "entryPoints": [
    "src/main.ts",
    "src/cli.ts",
    "src/config.ts",
    "src/domain",
    "src/contracts",
    "src/hopper",
    "src/ghidra",
    "src/process",
    "src/browser",
    "src/application",
    "src/server"
  ],
  "entryPointStrategy": "expand",
  "out": "docs/api",
  "tsconfig": "tsconfig.json",
  "exclude": ["**/*.test.ts", "tests/**", "dist/**", "node_modules/**"],
  "excludeExternals": true,
  "excludePrivate": true,
  "excludeProtected": false,
  "includeVersion": true,
  "readme": "none",
  "plugin": [],
  "gitRevision": "main",
  "disableGit": true,
  "basePath": "src",
  "sourceLinkTemplate": "https://github.com/morluto/rea/blob/{gitRevision}/src/{path}#L{line}"
}
