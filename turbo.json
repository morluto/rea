{
  "$schema": "https://turborepo.dev/schema.json",
  "tasks": {
    "build": {
      "inputs": [
        ".nvmrc",
        "package.json",
        "package-lock.json",
        "scripts/check-dependency-install.mjs",
        "scripts/generate-package-metadata.mjs",
        "scripts/lib/generated-file.mjs",
        "skills/reverse-engineer-anything/SKILL.md",
        "src/**/*.ts",
        "tsconfig.json",
        "tsconfig.build.json"
      ],
      "outputs": ["dist/**"]
    },
    "typecheck": {
      "inputs": [
        ".nvmrc",
        "package.json",
        "package-lock.json",
        "src/**/*.ts",
        "tests/**/*.ts",
        "tsconfig.json",
        "tsconfig.build.json",
        "vitest.config.ts"
      ]
    },
    "metadata:check": {
      "inputs": [
        "package.json",
        "package-lock.json",
        "scripts/generate-package-metadata.mjs",
        "scripts/lib/generated-file.mjs",
        "skills/reverse-engineer-anything/SKILL.md",
        "src/generatedPackageMetadata.ts"
      ]
    },
    "lint": {},
    "format:check": {},
    "knip": {},
    "jscpd": {},
    "scan:todos": {},
    "test:run": {
      "dependsOn": ["build"],
      "cache": false
    },
    "docs:check:built": {
      "dependsOn": ["build"],
      "cache": false
    }
  }
}
