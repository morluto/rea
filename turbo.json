{
  "$schema": "https://turborepo.dev/schema.json",
  "tasks": {
    "build": {
      "inputs": [
        ".nvmrc",
        "package.json",
        "package-lock.json",
        "scripts/check-dependency-install.mjs",
        "scripts/generate-package-metadata.mjs",
        "scripts/lib/generated-file.mjs",
        "skills/reverse-engineer-anything/SKILL.md",
        "src/**/*.ts",
        "tsconfig.json",
        "tsconfig.build.json"
      ],
      "outputs": ["dist/**", ".cache/tsconfig.build.tsbuildinfo"]
    },
    "typecheck": {
      "inputs": [
        ".nvmrc",
        "package.json",
        "package-lock.json",
        "src/**/*.ts",
        "tests/**/*.ts",
        "tsconfig.json",
        "tsconfig.build.json",
        "vitest.config.ts"
      ],
      "outputs": [".cache/tsconfig.typecheck.tsbuildinfo"]
    },
    "metadata:check": {
      "inputs": [
        "package.json",
        "package-lock.json",
        "scripts/generate-package-metadata.mjs",
        "scripts/lib/generated-file.mjs",
        "skills/reverse-engineer-anything/SKILL.md",
        "src/generatedPackageMetadata.ts"
      ]
    },
    "lint": {
      "inputs": [
        ".nvmrc",
        ".oxlintrc.json",
        "eslint.config.js",
        "package.json",
        "package-lock.json",
        "scripts/**/*.{cjs,cts,js,jsx,mjs,mts,ts,tsx}",
        "src/**/*.{cjs,cts,js,jsx,mjs,mts,ts,tsx}",
        "tests/**/*.{cjs,cts,js,jsx,mjs,mts,ts,tsx}",
        "vitest.config.ts"
      ]
    },
    "format:check": {},
    "knip": {
      "inputs": [
        ".nvmrc",
        "knip.json",
        "package.json",
        "package-lock.json",
        "scripts/**/*.{cjs,cts,js,jsx,mjs,mts,ts,tsx}",
        "src/**/*.ts",
        "tests/**/*.ts",
        "tsconfig.json",
        "tsconfig.build.json"
      ]
    },
    "jscpd": {
      "inputs": [
        ".gitignore",
        ".jscpd.json",
        "package.json",
        "package-lock.json",
        "src/**",
        "tests/**"
      ]
    },
    "scan:todos": {
      "inputs": [
        "bridge/**/*.{java,py}",
        "scripts/**/*.{cjs,cts,js,jsx,mjs,mts,ts,tsx}",
        "src/**/*.ts",
        "tests/**/*.ts"
      ]
    },
    "docs:api": {
      "inputs": [
        "package.json",
        "package-lock.json",
        "src/**/*.ts",
        "tsconfig.json",
        "typedoc.json"
      ],
      "outputs": ["build/api-docs/**"],
      "outputLogs": "new-only"
    },
    "test:run": {
      "dependsOn": ["build"],
      "cache": false
    },
    "docs:check:built": {
      "dependsOn": ["build", "docs:api"],
      "cache": false
    }
  }
}
