{
  "name": "@morluto/rea",
  "version": "0.2.1",
  "description": "Reverse engineering CLI and MCP server for coding agents to understand apps and build features.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/morluto/rea.git"
  },
  "homepage": "https://github.com/morluto/rea#readme",
  "bugs": {
    "url": "https://github.com/morluto/rea/issues"
  },
  "keywords": [
    "reverse-engineering",
    "binary-analysis",
    "coding-agents",
    "agent-skills",
    "cli",
    "mcp-server",
    "model-context-protocol",
    "static-analysis",
    "disassembler",
    "decompiler",
    "mcp",
    "hopper"
  ],
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "bin": {
    "rea": "scripts/rea.mjs"
  },
  "engines": {
    "node": ">=24.18.0 <25",
    "npm": ">=11.16.0 <12"
  },
  "packageManager": "npm@11.16.0",
  "files": [
    "dist",
    "bridge/hopper_bridge.py",
    "scripts/rea.mjs",
    "scripts/rebuild-native.mjs",
    "skills",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "check": "npm run typecheck && npm run lint && npm run format:check && npm test",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "knip": "knip",
    "lint:dead": "knip",
    "jscpd": "jscpd src/ tests/",
    "scan:todos": "node scripts/scan-todos.mjs",
    "start": "node dist/main.js",
    "pretest": "npm run build",
    "test": "vitest run",
    "pretest:coverage": "npm run build",
    "test:coverage": "vitest run --coverage.enabled --coverage.provider=v8",
    "test:verbose": "vitest run --reporter=verbose",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "verify:hopper": "npm run build && node scripts/verify-real-hopper.mjs",
    "build:fixtures": "node scripts/build-conformance-fixtures.mjs",
    "verify:fixtures": "npm run build:fixtures && node scripts/verify-conformance-fixtures.mjs",
    "verify:package": "npm run build && node scripts/verify-package.mjs",
    "config:print": "node scripts/print-mcp-config.mjs",
    "docs:generate": "typedoc",
    "prepack": "npm run build",
    "prepare": "husky",
    "rebuild:native": "node scripts/rebuild-native.mjs"
  },
  "lint-staged": {
    "*.{ts,mjs,json,md,yml,yaml}": "prettier --write",
    "*.ts": "oxlint --fix"
  },
  "dependencies": {
    "@modelcontextprotocol/server": "2.0.0-beta.3",
    "canonicalize": "3.0.0",
    "incur": "0.4.13",
    "node-pty": "1.1.0",
    "pino": "9.14.0",
    "ws": "8.21.0",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@modelcontextprotocol/client": "2.0.0-beta.3",
    "@types/node": "24.10.1",
    "@types/ws": "8.18.1",
    "@vitest/coverage-v8": "4.1.10",
    "husky": "9.1.7",
    "jscpd": "5.0.12",
    "knip": "6.26.0",
    "lint-staged": "16.4.0",
    "oxlint": "1.73.0",
    "prettier": "3.6.2",
    "typedoc": "0.28.20",
    "typescript": "5.9.3",
    "vitest": "4.1.10"
  },
  "allowScripts": {
    "node-pty@1.1.0": true
  }
}
