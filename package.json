{
  "name": "@morluto/rea",
  "version": "0.1.0",
  "description": "Reverse-engineering automation for Hopper Disassembler through one CLI and MCP server.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/morluto/rea.git"
  },
  "homepage": "https://github.com/morluto/rea#readme",
  "bugs": {
    "url": "https://github.com/morluto/rea/issues"
  },
  "keywords": [
    "reverse-engineering",
    "hopper",
    "disassembler",
    "decompiler",
    "mcp"
  ],
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "bin": {
    "rea": "scripts/rea.mjs"
  },
  "engines": {
    "node": ">=22"
  },
  "files": [
    "dist",
    "bridge",
    "scripts/rea.mjs",
    "skills",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "check": "npm run typecheck && npm run lint && npm run format:check && npm test",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint 'src/**/*.ts' 'tests/**/*.ts' vitest.config.ts",
    "start": "node dist/main.js",
    "pretest": "npm run build",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "verify:hopper": "npm run build && node scripts/verify-real-hopper.mjs",
    "verify:package": "npm run build && node scripts/verify-package.mjs",
    "config:print": "node scripts/print-mcp-config.mjs",
    "prepack": "npm run build"
  },
  "dependencies": {
    "@modelcontextprotocol/server": "2.0.0-beta.3",
    "incur": "0.4.13",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "9.39.2",
    "@modelcontextprotocol/client": "2.0.0-beta.3",
    "@types/node": "24.10.1",
    "eslint": "9.39.2",
    "prettier": "3.6.2",
    "typescript": "5.9.3",
    "typescript-eslint": "8.48.1",
    "vitest": "4.1.10"
  }
}
